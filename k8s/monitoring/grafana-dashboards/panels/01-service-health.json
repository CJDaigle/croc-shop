{
  "dashboard": {
    "id": null,
    "title": "Croc-Shop Service Health",
    "tags": ["croc-shop", "health"],
    "timezone": "",
    "panels": [
      {
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "mappings": [
              {"options": {"0": {"color": "red", "index": 0, "text": "DOWN"}}, "type": "value"},
              {"options": {"1": {"color": "green", "index": 1, "text": "UP"}}, "type": "value"}
            ],
            "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "red", "value": 0}]},
            "unit": "short"
          },
          "overrides": []
        },
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
        "id": 1,
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "justifyMode": "auto",
          "orientation": "horizontal",
          "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
          "textMode": "auto"
        },
        "targets": [
          {
            "expr": "up{job=\"kubernetes-pods\",kubernetes_namespace=~\"croc-shop-.*\"}",
            "legendFormat": "{{kubernetes_namespace}}/{{kubernetes_pod_name}}",
            "refId": "A"
          }
        ],
        "title": "Service Health Status",
        "type": "stat"
      }
    ],
    "refresh": "5s",
    "schemaVersion": 27,
    "style": "dark",
    "templating": {"list": []},
    "time": {"from": "now-1h", "to": "now"},
    "timepicker": {},
    "uid": "croc-shop-health",
    "version": 1
  }
}
